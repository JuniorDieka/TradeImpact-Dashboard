# Application
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# Database
MONGODB_URI=mongodb://localhost:27017/tradeimpact-dashboard
# For MongoDB Atlas cloud database, use:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/tradeimpact-dashboard?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h

# CORS
CORS_ORIGIN=http://localhost:4200
